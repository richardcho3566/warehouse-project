# Local default
DEBUG=True
SECRET_KEY=change-this-dev-secret
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite is used by default.
# To use PostgreSQL, uncomment and set values below.
# DB_ENGINE=postgresql
# DB_NAME=warehouse_project
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Or use DATABASE_URL directly.
# DATABASE_URL=postgres://user:password@localhost:5432/warehouse_project
